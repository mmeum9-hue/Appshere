rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Primitives & Global Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mmeum9@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- Entity Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt', 'status'])
        && data.keys().size() == 6
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.role is string && (data.role == 'user' || data.role == 'admin')
        && data.createdAt is int
        && data.status is string && (data.status == 'active' || data.status == 'suspended');
    }

    function isValidFile(data) {
      return data.keys().hasAll(['id', 'name', 'size', 'type', 'uploadedAt', 'downloadUrl', 'downloadsCount', 'uploadedBy', 'uploaderEmail', 'isPublic'])
        && data.keys().size() >= 10 && data.keys().size() <= 15
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 256
        && data.size is int && data.size >= 0
        && data.type is string && data.type.size() <= 50
        && data.uploadedAt is int
        && data.downloadUrl is string && data.downloadUrl.size() <= 2048
        && data.downloadsCount is int && data.downloadsCount >= 0
        && data.uploadedBy is string && data.uploadedBy.size() <= 128
        && data.uploaderEmail is string && data.uploaderEmail.size() <= 256
        && data.isPublic is bool
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 2048))
        && (!data.keys().hasAny(['appIcon']) || (data.appIcon is string && data.appIcon.size() <= 2048))
        && (!data.keys().hasAny(['screenshots']) || (data.screenshots is list && data.screenshots.size() <= 10))
        && (!data.keys().hasAny(['rating']) || (data.rating is number))
        && (!data.keys().hasAny(['ratingsCount']) || (data.ratingsCount is int));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'fileId', 'rating', 'comment', 'userName', 'userId', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.fileId is string && data.fileId.size() <= 128
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.userName is string && data.userName.size() <= 100
        && data.userId is string && data.userId.size() <= 128
        && data.createdAt is int;
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['id', 'userId', 'fileId', 'createdAt'])
        && data.keys().size() == 4
        && data.id is string && data.id.size() <= 256
        && data.userId is string && data.userId.size() <= 128
        && data.fileId is string && data.fileId.size() <= 128
        && data.createdAt is int;
    }

    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      // On create, a new user can only register themselves with role = 'user' and status = 'active'
      allow create: if isSignedIn() 
                    && isOwner(userId) 
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().role == 'user'
                    && incoming().status == 'active'
                    && incoming().email == request.auth.token.email;
                    
      // Only admins can modify user roles or suspend accounts
      allow update: if isAdmin() 
                    && isValidId(userId)
                    && isValidUser(incoming());
                    
      allow delete: if isAdmin() && isValidId(userId);
    }

    // --- Files Collection ---
    match /files/{fileId} {
      // Allow get/list of public files, or if owner or admin
      allow get: if resource == null || resource.data.isPublic == true || (isSignedIn() && (resource.data.uploadedBy == request.auth.uid || isAdmin()));
      allow list: if resource.data.isPublic == true || (isSignedIn() && (resource.data.uploadedBy == request.auth.uid || isAdmin()));

      allow create: if isSignedIn()
                    && isValidId(fileId)
                    && isValidFile(incoming())
                    && incoming().uploadedBy == request.auth.uid
                    && incoming().uploaderEmail == request.auth.token.email
                    && incoming().downloadsCount == 0;

      allow update: if isSignedIn()
                    && isValidId(fileId)
                    && isValidFile(incoming())
                    // Allow normal user to update their own files, or anyone to increment downloadsCount, or admins
                    && (
                      isAdmin() ||
                      // Action: owner update metadata
                      (resource.data.uploadedBy == request.auth.uid && incoming().uploadedBy == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'isPublic', 'appIcon', 'screenshots', 'rating', 'ratingsCount'])) ||
                      // Action: increment downloadsCount (from download action)
                      (incoming().diff(existing()).affectedKeys().hasOnly(['downloadsCount']) && incoming().downloadsCount == existing().downloadsCount + 1)
                    );

      allow delete: if isSignedIn()
                    && isValidId(fileId)
                    && (resource.data.uploadedBy == request.auth.uid || isAdmin());
    }

    // --- Favorites Collection ---
    match /favorites/{favoriteId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
                    && isValidId(favoriteId)
                    && isValidFavorite(incoming())
                    && incoming().userId == request.auth.uid
                    // Relational check: Ensure the file exists before favoriting
                    && exists(/databases/$(database)/documents/files/$(incoming().fileId));

      allow delete: if isSignedIn()
                    && isValidId(favoriteId)
                    && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- Reviews Collection ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow list: if true;
      
      allow create: if isValidId(reviewId)
                    && isValidReview(incoming())
                    && exists(/databases/$(database)/documents/files/$(incoming().fileId));
                    
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
